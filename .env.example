# Django 密钥配置
# 开发环境使用 DJANGO_DEV_SECRET_KEY；生产环境使用 DJANGO_PRODUCT_SECRET_KEY。
DJANGO_DEV_SECRET_KEY=change-me-in-development
DJANGO_PRODUCT_SECRET_KEY=change-me-in-production

# Django 基础配置
# 多个 host 使用英文逗号分隔。
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_LANGUAGE_CODE=zh-hans
DJANGO_TIME_ZONE=Asia/Shanghai

# 静态文件与用户上传文件
DJANGO_STATIC_URL=/static/
DJANGO_STATIC_ROOT=staticfiles
DJANGO_MEDIA_URL=/media/
DJANGO_MEDIA_ROOT=media

# 数据库配置
# 默认示例使用 PostgreSQL，请根据本地数据库账号和库名调整。
DB_ENGINE=django.db.backends.postgresql
DB_NAME=secondhand_platform
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Redis 配置
# 本地默认按项目配置连接 localhost:6380，并为缓存、Channels、Celery 分配不同 DB。
DJANGO_CACHE_URL=redis://localhost:6380/2
CHANNEL_REDIS_URL=redis://localhost:6380/3
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/1
